# =============================================================================
# Plataforma-Aut — variáveis de ambiente
#
# Copie para .env e preencha. O .env NUNCA vai para o repositório.
# Em produção, estes valores vivem nas Environment Variables da Vercel.
# =============================================================================

# --- Ambiente ----------------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# --- Banco de dados (Supabase) -----------------------------------------------
# ATENÇÃO: são DUAS URLs diferentes, de propósito.
#
# DATABASE_URL  → transaction pooler (porta 6543). Usada pela API em runtime.
#                 Serverless abre uma conexão por invocação; o pooler é o que
#                 impede o Postgres de esgotar o limite de conexões.
#
# DATABASE_DIRECT_URL → conexão direta (porta 5432). Usada SÓ pelo Alembic.
#                 Migrations precisam de uma sessão real, que o pooler em
#                 transaction mode não oferece.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql+asyncpg://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres

# Banco separado para os testes de integração — eles truncam tabelas entre um
# teste e outro. Apontar isto para o banco de desenvolvimento apagaria seus dados.
TEST_DATABASE_URL=postgresql+asyncpg://usuario@localhost:5432/plataforma_aut_test

# Senha do admin criado pelo seed. NÃO existe valor padrão de propósito: o seed
# falha se esta variável não estiver definida. Credencial default é como a
# maioria dos vazamentos por "senha conhecida" começa.
#   SEED_ADMIN_EMAIL=admin@suaempresa.com.br
#   SEED_ADMIN_PASSWORD='...'   uv run python -m src.infrastructure.database.seed

# --- Autenticação -------------------------------------------------------------
# Gere com: openssl rand -hex 32
JWT_SECRET_KEY=troque-isto-por-um-segredo-de-32-bytes-em-hex
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Domínio do cookie de refresh. Com ponto na frente, vale para os subdomínios
# (dominio.com.br e api.dominio.com.br compartilham o cookie).
# Em desenvolvimento, deixe vazio.
COOKIE_DOMAIN=

# --- CORS ---------------------------------------------------------------------
# Origens explícitas, separadas por vírgula. Nunca "*" com credentials.
CORS_ORIGINS=http://localhost:3000

# --- Supabase Storage (fotos dos veículos) ------------------------------------
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # secreta — só no backend, jamais no frontend
SUPABASE_STORAGE_BUCKET=vehicles

# --- Rate limiting (Upstash Redis) --------------------------------------------
# Rate limit em memória não funciona em serverless: cada instância teria o seu
# próprio contador. O Redis é o contador compartilhado.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- E-mail transacional (Resend) ---------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=nao-responda@dominio.com.br
ADMIN_NOTIFICATION_EMAIL=contato@dominio.com.br

# --- Revalidação do frontend (ISR sob demanda) -------------------------------
# Quando o admin muda um anúncio, a API avisa o Next para regenerar as páginas
# na hora, em vez de esperar o ciclo de 5 min do ISR.
#   FRONTEND_URL      → onde o Next está (ex: https://dominio.com.br)
#   REVALIDATE_SECRET → segredo compartilhado entre a API e o Next. Gere com
#                       `openssl rand -hex 32` e use O MESMO valor nos dois lados.
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=

# --- Frontend (apps/web) ------------------------------------------------------
# Prefixo NEXT_PUBLIC_ = exposto ao browser. Só coloque aqui o que for público.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
